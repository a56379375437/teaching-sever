generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 题目类型
enum QuestionType {
  SINGLE_CHOICE    // 单选题
  MULTIPLE_CHOICE  // 多选题
  JUDGMENT         // 判断题
  FILL_BLANK       // 填空题
  CALCULATION      // 计算题
  SHORT_ANSWER     // 简答题
}

// 难度等级
enum QuestionLevel {
  EASY      // 容易
  MEDIUM    // 中等
  HARD      // 困难
}

// 知识点分类
enum KnowledgeUnit {
  LARGE_NUMBER_LAW      // 大数定律
  CENTRAL_LIMIT_THEOREM // 中心极限定理
  CONFIDENCE_INTERVAL   // 置信区间
}

// 主题目表（核心）
model Question {
  id             Int            @id @default(autoincrement())
  title          String         // 题干
  type           QuestionType   // 题目类型
  level          QuestionLevel  // 难度
  knowledgeUnit  KnowledgeUnit  // 所属知识点
  score          Int            @default(5) // 分值
  creator        User?          @relation("QuestionCreator",fields: [creatorId], references: [id]) // 创建者
  creatorId     Int?           // 创建者ID
  createdAt      DateTime       @default(now())//创建时间
  updatedAt      DateTime       @updatedAt // 更新时间

  // 各题型关联
  options        QuestionOption[]
  singleChoice   SingleChoice?
  multipleChoice MultipleChoice?
  judgment       Judgment?
  fillBlank      FillBlank?
  calculation    Calculation?
  shortAnswer    ShortAnswer?

  // 索引
  @@index([title])
  @@index([type])
  @@index([knowledgeUnit])
  @@index([creatorId])
}

// 题目选项（通用，单选/多选/判断共用）
model QuestionOption {
  id          Int      @id @default(autoincrement())
  content     String   // 选项内容
  isCorrect   Boolean  // 是否正确
  order       Int      @default(0)// 排序

  // 关联
  questionId  Int
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

// 单选题
model SingleChoice {
  id          Int      @id @default(autoincrement())
  questionId  Int      @unique
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 多选题
model MultipleChoice {
  id          Int      @id @default(autoincrement())
  questionId  Int      @unique
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 判断题
model Judgment {
  id          Int      @id @default(autoincrement())
  answer      Boolean  // 正确答案：true / false
  questionId  Int      @unique
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 填空题
model FillBlank {
  id            Int      @id @default(autoincrement())
  standardAnswer String  // 标准答案
  questionId    Int      @unique
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 计算题
model Calculation {
  id              Int      @id @default(autoincrement())
  standardProcess String? // 标准解题步骤
  standardAnswer  String  // 标准答案
  questionId      Int      @unique
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 简答题
model ShortAnswer {
  id              Int      @id @default(autoincrement())
  standardAnswer  String   // 参考答案要点
  questionId      Int      @unique
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// 用户管理：

// 角色枚举
enum Role {
  STUDENT    // 学生
  TEACHER    // 教师
  ADMIN      // 管理员
}

// 用户模型
model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique                  // 登录账号
  password      String                                  // 加密后的密码
  name          String?                                 // 真实姓名
  role          Role           @default(STUDENT)        // 用户角色
  score         Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // 关联：作为教师创建的题目
  createdQuestions Question[]  @relation("QuestionCreator")

  // 关联：作为学生进行的测评记录
  quizRecords     QuizRecord[]

  @@index([role])
}

// 测评记录 (用于查看学生各知识单元测评情况)
model QuizRecord {
  id            Int           @id @default(autoincrement())
  score         Int           // 此次测评得分
  totalScore    Int           // 总分
  knowledgeUnit KnowledgeUnit // 所属知识单元
  completedAt   DateTime      @default(now())

  // 关联学生
  studentId     Int
  student       User          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([knowledgeUnit])
}